# ============================================
# ImmoFind — Variables d'environnement
# ============================================
# Pour le développement local (SQLite) :
#   DATABASE_URL="file:./dev.db"
#   Et changer provider dans prisma/schema.prisma
#   de "postgresql" → "sqlite"
#
# Pour Railway (production) :
#   Railway injecte DATABASE_URL automatiquement
#   Garder provider = "postgresql" dans le schéma
# ============================================

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/immofind"
JWT_SECRET="changez-ce-secret-par-une-chaine-tres-longue"
JWT_EXPIRES_IN="7d"
PORT=8080
CLOUDINARY_CLOUD_NAME="votre-cloud-name"
CLOUDINARY_API_KEY="votre-api-key"
CLOUDINARY_API_SECRET="votre-api-secret"
